generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  

}



model User {

  id               String         @id @default(uuid())

  messages  Message[]

  email            String         @unique

  password         String

  name             String?

  submissions      Submission[]

  createdAt        DateTime       @default(now())

  role             String         @default("USER")

  streak           Int            @default(0)

  lastActivityDate DateTime       @default(now())



  classroomsTeacher Classroom[]    @relation("TeacherClassrooms")

  classroomsStudent Classroom[]    @relation("StudentClassrooms")

  assignments       Assignment[]   @relation("StudentAssignments")

  notifications     Notification[]

  createdProblems Problem[]        @relation("ProblemAuthor")


}

enum ProblemType  {
  LESSON //Probleme pt progresul lectiilor
  PRACTICE // probleme pt exersare
  HOMEWORK // probleme create direct de prof pentru teme 
}

model Module {

  id          String   @id @default(uuid())

  title       String

  description String?

  language    String

  order       Int      @default(0)

  lessons     Lesson[]

  createdAt   DateTime @default(now())

}



model Lesson {

  id          Int       @id @default(autoincrement())

  title       String

  content     String    @db.Text

  description String

  order       Int       @default(0)

  moduleId    String

  module      Module    @relation(fields: [moduleId], references: [id])

  problems    Problem[]

  createdAt   DateTime  @default(now())

}



model Problem {

  id          String       @id @default(uuid())

  title       String

  description String

  difficulty  String

  testCases   Json

  type        ProblemType @default (PRACTICE)
  authorId    String?     //pt problemele create de autor
  author      User?       @relation("ProblemAuthor", fields: [authorId], references: [id])


  lessonId    Int?

  lesson      Lesson?      @relation(fields: [lessonId], references: [id])

  submissions Submission[]

  assignments Assignment[]

}



model Submission {

  id          String   @id @default(uuid())

  code        String

  language    String

  status      String   @default("PENDING")

  output      String?

  testResults Json?

  createdAt   DateTime @default(now())

  problemId   String

  problem     Problem  @relation(fields: [problemId], references: [id])

  userId      String?

  user        User?    @relation(fields: [userId], references: [id])

}



model Classroom {

  id          String       @id @default(uuid())

  name        String

  description String?

  inviteCode  String       @unique

  teacherId   String

  teacher     User         @relation("TeacherClassrooms", fields: [teacherId], references: [id])

  students    User[]       @relation("StudentClassrooms")

  assignments Assignment[]

  createdAt   DateTime     @default(now())

}



model Assignment {

  id          String     @id @default(uuid())

  title       String

  language    String

  status      String     @default("PENDING")

  grade       Int?

  classroomId String?

  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  problemId   String

  problem     Problem    @relation(fields: [problemId], references: [id])

  studentId   String

  student     User       @relation("StudentAssignments", fields: [studentId], references: [id])

  createdAt   DateTime   @default(now())

}



model Notification {

  id        String   @id @default(uuid())

  userId    String

  user      User     @relation(fields: [userId], references: [id])

  message   String

  type      String

  read      Boolean  @default(false)

  createdAt DateTime @default(now())

}

model Channel {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id]) 
  
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
}